# Secrets — never commit tokens or credentials
.env
.env.*
!.env.example
*.token
*.secret
secrets/
*-credentials.json
*.pem

# Claude Code local settings (machine-specific permissions, not shared config)
.claude/settings.local.json

# Python
__pycache__/
*.pyc
.venv/
uv.lock.tmp

# Archived forecast data — generated by the fetchers, not source.
# .gitkeep files preserve the directory shape for a fresh clone.
data/raw/**
!data/raw/.gitkeep
data/points.parquet

# Downloaded/cached tooling artifacts (e.g. icon_extractor.py's cdo remap
# weight bundle) — large, re-downloadable, not source.
data/cache/

# Editor / OS noise
.vscode/
.idea/
Thumbs.db
